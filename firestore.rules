rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MARKETGAZER SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict Path-Based Ownership model for all user-specific data. 
     * Authorization is derived directly from the document path, ensuring that users can 
     * only access their own profiles, portfolios, and preferences.
     *
     * Last Updated: 2024-05-24T12:00:00Z (Ensuring explicit update permissions for profiles)
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for individual user profiles.
     * We allow all operations for the owner of the document.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description User-created virtual portfolios.
     */
    match /users/{userId}/portfolios/{portfolioId} {
      allow read, write: if isOwner(userId);

      match /holdings/{holdingId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Personalized user preferences (Singleton).
     */
    match /users/{userId}/preferences/userPreference {
      allow read, write: if isOwner(userId);
    }

    /**
     * @description Publicly available stock information.
     */
    match /stocks/{stockId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;

      match /historicalData/{dataId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /predictions/{predictionId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if false;
      }

      match /riskAssessments/{assessmentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if false;
      }
    }

    /**
     * @description Aggregated financial news articles.
     */
    match /newsArticles/{articleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}